{
  "baseDir": "./src",
  "references": [
    { "path": "./../../.common/config/typescript/tsconfig.node.json" },
    { "path": "./../../.common/config/typescript/tsconfig.app.json" }
  ],
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "typeRoots": ["node_modules/@types"],
  "include": ["./src/**/*"],
  "exclude": ["lib", "lib-cjs", "node_modules"]
}
