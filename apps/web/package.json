{
  "name": "@divvy/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "postinstall": "playwright install chromium",
    "start:dev": "vite --host",
    "start:dux": "storybook dev -p 6006",
    "start:prod": "npm run build:prod && node server.js",
    "build:prod": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build-storybook": "storybook build",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run --reporter=dot",
    "test:vis": "playwright test",
    "test:uss": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@tailwindcss/vite": "^4.3.2",
    "express": "^4.22.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "storybook": "^10.4.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
