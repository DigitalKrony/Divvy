{
  "users": {
    "schema": {
      "id": "$i",
      "uuid": "$random( type: hex-key, lengths: [8, 4, 4, 4, 12])",
      "first_name": "{{person.firstName}}",
      "last_name": "{{person.lastName}}",
      "display_name": "{{internet.username}}",
      "phone_number": "{{phone.number}}",
      "email_address": "{{internet.email}}",
      "address": {
        "address_line_1": "{{location.streetAddress(false)}}",
        "address_line_2": "{{location.secondaryAddress}}",
        "city": "{{location.city}}",
        "state": "{{location.state}}",
        "zip_code": "{{location.zipCode}}",
        "id": 0,
        "user_id": 0
      },
      "pay_accounts": {
        "array": {
          "value": "$random(type: hex-key, lengths: [8, 4, 4, 4, 12])",
          "count": 0.3,
          "unique": true
        }
      }
    },
    "count": 45
  },
  "groups": {
    "schema": {
      "id": "$i",
      "uuid": "$random( type: hex-key, lengths: [8, 4, 4, 4, 12])",
      "name": "{{company.name}}",
      "description": "{{lorem.paragraph}}",
      "created_at": "{{date.past}}",
      "updated_at": "{{date.recent}}",
      "group_image": "{{image.avatarGitHub}}",
      "group_header_image": "{{image.urlPicsumPhotos({width: 800, blur: 4, grayscale: true })}}",
      "location": "{{location.streetAddress({useFullAddress: true})}}",
      "users": {
        "array": {
          "value": "$random(type: connection, object: users, key: uuid)",
          "count": 1.6,
          "unique": false
        }
      },
      "events": {
        "array": {
          "value": "$random(type: connection, object: events, key: uuid)",
          "count": 1.3,
          "unique": false
        }
      }
    },
    "count": 15
  },
  "events": {
    "schema": {
      "id": "$i",
      "uuid": "$random( type: hex-key, lengths: [8, 4, 4, 4, 12])",
      "title": "{{commerce.productName}}",
      "description": "{{lorem.paragraph}}",
      "location": "{{location.streetAddress({useFullAddress: true})}}",
      "start_date": "{{date.future}}",
      "end_date": "{{date.future}}",
      "users": {
        "array": {
          "value": "$random(type: connection, object: users, key: uuid)",
          "count": 1.10,
          "unique": false
        }
      },
      "groups": {
        "array": {
          "value": "$random(type: connection, object: groups, key: uuid)",
          "count": 1.3,
          "unique": false
        }
      }
    },
    "count": 20
  }
}